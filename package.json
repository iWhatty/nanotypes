{
    "name": "nanotypes",
    "version": "0.2.2",
    "description": "Minimal, runtime-safe type checks for modern JS & TS",
    "type": "module",
    "engines": {
        "node": ">=18"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "ADDITIONAL_TERMS.md",
        "robots.txt"
    ],
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./auto": {
            "types": "./dist/auto.d.ts",
            "import": "./dist/auto.js",
            "default": "./dist/auto.js"
        }
    },
    "scripts": {
        "build": "node esbuild.config.js",
        "test": "node ./test/smokeTest.js"
    },
    "keywords": [
        "type-checking",
        "vanilla-js",
        "runtime-types",
        "tree-shakable",
        "lightweight",
        "jsdoc-friendly"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/iWhatty/nanotypes.git"
    },
    "author": "WATT3D <WATT3D@protonmail.com>",
    "license": "SEE LICENSE IN LICENSE",
    "sideEffects": false,
    "devDependencies": {
        "esbuild": "^0.25.4"
    }
}
